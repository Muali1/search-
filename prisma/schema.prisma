generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activity_log {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  log_name     String?   @db.VarChar(255)
  description  String    @db.MediumText
  subject_type String?   @db.VarChar(255)
  event        String?   @db.VarChar(255)
  subject_id   BigInt?   @db.UnsignedBigInt
  causer_type  String?   @db.VarChar(255)
  causer_id    BigInt?   @db.UnsignedBigInt
  properties   String?   @db.LongText
  batch_uuid   String?   @db.Char(36)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)

  @@index([log_name], map: "activity_log_log_name_index")
  @@index([causer_type, causer_id], map: "causer")
  @@index([subject_type, subject_id], map: "subject")
}

model admins {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name              String    @db.VarChar(255)
  email             String    @unique(map: "admins_email_unique") @db.VarChar(250)
  email_verified_at DateTime? @db.Timestamp(0)
  password          String    @db.VarChar(255)
  country_code      String    @default("+966") @db.VarChar(255)
  phone             String    @db.VarChar(255)
  job               String    @db.VarChar(255)
  avatar            String    @default("uploads/users/avatars/default-user-image.png") @db.VarChar(255)
  nationalty_id     BigInt    @db.UnsignedBigInt
  country_id        BigInt    @db.UnsignedBigInt
  city_id           BigInt    @db.UnsignedBigInt
  lang_id           BigInt    @db.UnsignedBigInt
  status            Boolean   @default(true)
  remember_token    String?   @db.VarChar(100)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)

  @@index([city_id], map: "admins_city_id_foreign")
  @@index([country_id], map: "admins_country_id_foreign")
  @@index([lang_id], map: "admins_lang_id_foreign")
  @@index([nationalty_id], map: "admins_nationalty_id_foreign")
}

